@model EntityBuilder.ViewModels.TableListViewModel
@{
    ViewData["Title"] = "Query Builder";
}

<div class="eb-page-header">
    <div>
        <h2 class="eb-page-title"><i class="bi bi-columns-gap me-2"></i>Query Builder</h2>
        <p class="eb-page-subtitle">
            <i class="bi bi-database me-1"></i> <strong>@Model.DatabaseName</strong> &mdash; @Model.Tables.Count table(s)
        </p>
    </div>
</div>

@Html.AntiForgeryToken()

<!-- Main Table Selection -->
<div class="eb-card mb-3">
    <div class="eb-card-header">
        <i class="bi bi-table me-2"></i> Main Table
    </div>
    <div class="eb-card-body">
        <select id="mainTable" class="eb-select">
            <option value="">-- Select a table --</option>
            @foreach (var t in Model.Tables)
            {
                <option value="@t.SchemaName|@t.TableName">[@t.SchemaName].[@t.TableName] (@t.RowCount.ToString("N0") rows)</option>
            }
        </select>
    </div>
</div>

<!-- JOINs Section -->
<div class="eb-card mb-3">
    <div class="eb-card-header">
        <i class="bi bi-diagram-3 me-2"></i> JOINs
        <button id="addJoin" class="eb-btn-add" disabled>
            <i class="bi bi-plus-lg"></i> Add Join
        </button>
    </div>
    <div class="eb-card-body" id="joinsContainer">
        <p class="eb-empty-message" id="noJoinsMessage">
            <i class="bi bi-info-circle me-1"></i> No joins added. Select a main table first.
        </p>
    </div>
</div>

<!-- WHERE Conditions Section -->
<div class="eb-card mb-3">
    <div class="eb-card-header">
        <i class="bi bi-funnel me-2"></i> WHERE Conditions
        <button id="addWhere" class="eb-btn-add" disabled>
            <i class="bi bi-plus-lg"></i> Add Condition
        </button>
    </div>
    <div class="eb-card-body" id="whereContainer">
        <p class="eb-empty-message" id="noWhereMessage">
            <i class="bi bi-info-circle me-1"></i> No conditions added. Select a main table first.
        </p>
    </div>
</div>

<!-- GROUP BY Section -->
<div class="eb-card mb-3">
    <div class="eb-card-header">
        <i class="bi bi-collection me-2"></i> GROUP BY
        <div>
            <button id="addGroupBy" class="eb-btn-add" disabled>
                <i class="bi bi-plus-lg"></i> Add Column
            </button>
            <button id="addAggregate" class="eb-btn-add ms-1" disabled>
                <i class="bi bi-calculator"></i> Add Aggregate
            </button>
        </div>
    </div>
    <div class="eb-card-body" id="groupByContainer">
        <p class="eb-empty-message" id="noGroupByMessage">
            <i class="bi bi-info-circle me-1"></i> No grouping. Results will return individual rows.
        </p>
    </div>
</div>

<!-- ORDER BY Section -->
<div class="eb-card mb-3">
    <div class="eb-card-header">
        <i class="bi bi-sort-down me-2"></i> ORDER BY
        <button id="addOrderBy" class="eb-btn-add" disabled>
            <i class="bi bi-plus-lg"></i> Add Sort
        </button>
    </div>
    <div class="eb-card-body" id="orderByContainer">
        <p class="eb-empty-message" id="noOrderByMessage">
            <i class="bi bi-info-circle me-1"></i> No sorting applied. Default order will be used.
        </p>
    </div>
</div>

<!-- SELECT Columns Section -->
<div class="eb-card mb-3">
    <div class="eb-card-header">
        <i class="bi bi-check2-square me-2"></i> SELECT Columns
        <span class="eb-badge" id="colCountBadge"></span>
    </div>
    <div class="eb-card-body" id="columnsContainer">
        <p class="eb-empty-message" id="noColumnsMessage">
            <i class="bi bi-info-circle me-1"></i> Select a main table to see available columns.
        </p>
    </div>
</div>

<!-- Execute -->
<div class="eb-execute-bar">
    <button id="executeQuery" class="eb-btn-execute" disabled>
        <i class="bi bi-play-fill me-2"></i> Execute Query
    </button>
    <button id="sendReportEmail" class="eb-btn-execute" style="background:#374151;" disabled>
        <i class="bi bi-envelope-fill me-2"></i> Send Report to Email
    </button>
    <button id="scheduleReport" class="eb-btn-execute" style="background:#1D4ED8;" disabled>
        <i class="bi bi-clock-fill me-2"></i> Schedule Report
    </button>
    <div id="loadingSpinner" class="eb-spinner d-none">
        <div class="spinner-border spinner-border-sm" role="status"></div>
        <span>Running query...</span>
    </div>
    <div id="reportSpinner" class="eb-spinner d-none">
        <div class="spinner-border spinner-border-sm" role="status"></div>
        <span>Sending report...</span>
    </div>
</div>
<div id="reportFeedback" class="d-none" style="margin-top:0.5rem;padding:0.5rem 1rem;border-radius:6px;font-size:0.875rem;"></div>

<!-- Send Report Modal -->
<div class="modal fade" id="sendReportModal" tabindex="-1" aria-labelledby="sendReportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:12px;border:none;box-shadow:0 8px 32px rgba(0,0,0,0.2);">
            <div class="modal-header" style="background:#374151;color:#fff;border-radius:12px 12px 0 0;border-bottom:none;">
                <h5 class="modal-title" id="sendReportModalLabel"><i class="bi bi-envelope-fill me-2"></i>Send Report to Email</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding:1.5rem;">
                <div class="mb-3">
                    <label for="reportSubject" class="form-label fw-semibold">Email Subject</label>
                    <input type="text" class="form-control" id="reportSubject" value="Entity Builder Report" placeholder="Fill in the email subject">
                </div>
                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="sendToLoginEmail" checked>
                        <label class="form-check-label" for="sendToLoginEmail">Send to my login email</label>
                    </div>
                </div>
                <div class="mb-3 d-none" id="customEmailGroup">
                    <label for="customRecipientEmail" class="form-label fw-semibold">Recipient Email</label>
                    <input type="email" class="form-control" id="customRecipientEmail" placeholder="Enter recipient email address">
                </div>
            </div>
            <div class="modal-footer" style="border-top:1px solid #e5e7eb;">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn text-white" id="confirmSendReport" style="background:#DC2626;">
                    <i class="bi bi-send-fill me-1"></i> Send Report
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Schedule Report Modal -->
<div class="modal fade" id="scheduleReportModal" tabindex="-1" aria-labelledby="scheduleReportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:12px;border:none;box-shadow:0 8px 32px rgba(0,0,0,0.2);">
            <div class="modal-header" style="background:#1D4ED8;color:#fff;border-radius:12px 12px 0 0;border-bottom:none;">
                <h5 class="modal-title" id="scheduleReportModalLabel"><i class="bi bi-clock-fill me-2"></i>Schedule Report</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding:1.5rem;">
                <div class="mb-3">
                    <label for="scheduleSubject" class="form-label fw-semibold">Email Subject</label>
                    <input type="text" class="form-control" id="scheduleSubject" value="Entity Builder Report" placeholder="Fill in the email subject">
                </div>
                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="scheduleSendToLoginEmail" checked>
                        <label class="form-check-label" for="scheduleSendToLoginEmail">Send to my login email</label>
                    </div>
                </div>
                <div class="mb-3 d-none" id="scheduleCustomEmailGroup">
                    <label for="scheduleCustomEmail" class="form-label fw-semibold">Recipient Email</label>
                    <input type="email" class="form-control" id="scheduleCustomEmail" placeholder="Enter recipient email address">
                </div>
                <hr>
                <div class="mb-3">
                    <label for="scheduleFrequency" class="form-label fw-semibold">Frequency</label>
                    <select class="form-select" id="scheduleFrequency">
                        <option value="0">Once</option>
                        <option value="1">Daily</option>
                        <option value="2">Weekly</option>
                        <option value="3">Monthly</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label for="scheduleTime" class="form-label fw-semibold">Time of Day</label>
                    <input type="time" class="form-control" id="scheduleTime" value="08:00">
                </div>
                <div class="mb-3 d-none" id="scheduleDateGroup">
                    <label for="scheduleDate" class="form-label fw-semibold">Date</label>
                    <input type="date" class="form-control" id="scheduleDate">
                </div>
                <div class="mb-3 d-none" id="scheduleDayOfWeekGroup">
                    <label for="scheduleDayOfWeek" class="form-label fw-semibold">Day of Week</label>
                    <select class="form-select" id="scheduleDayOfWeek">
                        <option value="0">Sunday</option>
                        <option value="1" selected>Monday</option>
                        <option value="2">Tuesday</option>
                        <option value="3">Wednesday</option>
                        <option value="4">Thursday</option>
                        <option value="5">Friday</option>
                        <option value="6">Saturday</option>
                    </select>
                </div>
                <div class="mb-3 d-none" id="scheduleDayOfMonthGroup">
                    <label for="scheduleDayOfMonth" class="form-label fw-semibold">Day of Month</label>
                    <input type="number" class="form-control" id="scheduleDayOfMonth" min="1" max="31" value="1">
                </div>
            </div>
            <div class="modal-footer" style="border-top:1px solid #e5e7eb;">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn text-white" id="confirmScheduleReport" style="background:#1D4ED8;">
                    <i class="bi bi-clock-fill me-1"></i> Schedule Report
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Scheduled Reports Panel -->
<div class="eb-card mb-3 mt-3" id="scheduledReportsPanel">
    <div class="eb-card-header">
        <span><i class="bi bi-clock-history me-2"></i> Scheduled Reports</span>
        <button id="refreshScheduledReports" class="eb-btn-add" title="Refresh">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>
    <div class="eb-card-body p-0">
        <div id="scheduledReportsEmpty" class="eb-empty-message m-3">
            <i class="bi bi-info-circle me-1"></i> No scheduled reports.
        </div>
        <div class="table-responsive" id="scheduledReportsTableContainer" style="display:none;">
            <table class="eb-results-table" style="margin:0;">
                <thead>
                    <tr>
                        <th style="padding:0.5rem 0.75rem;">Subject</th>
                        <th style="padding:0.5rem 0.75rem;">Recipient</th>
                        <th style="padding:0.5rem 0.75rem;">Frequency</th>
                        <th style="padding:0.5rem 0.75rem;">Next Run</th>
                        <th style="padding:0.5rem 0.75rem;">Status</th>
                        <th style="padding:0.5rem 0.75rem;">Actions</th>
                    </tr>
                </thead>
                <tbody id="scheduledReportsBody"></tbody>
            </table>
        </div>
    </div>
</div>

<!-- Generated SQL -->
<div id="sqlSection" class="d-none">
    <div class="eb-card mb-3">
        <div class="eb-card-header">
            <span><i class="bi bi-code-slash me-2"></i> Generated SQL</span>
            <button id="copySqlBtn" class="eb-btn-add" title="Copy to clipboard">
                <i class="bi bi-clipboard"></i> Copy
            </button>
        </div>
        <div class="eb-card-body p-0">
            <pre class="eb-sql-preview" id="sqlPreview"></pre>
        </div>
    </div>
</div>

<!-- Results -->
<div id="resultsSection" class="d-none">
    <div class="eb-card eb-results-card">
        <div class="eb-card-header eb-results-header" id="resultsHeader"></div>
        <!-- View Mode Tabs -->
        <div class="eb-view-tabs d-none" id="viewModeTabs">
            <button class="eb-view-tab active" data-view="grid">
                <i class="bi bi-table me-1"></i> Data Grid
            </button>
            <button class="eb-view-tab" data-view="bar">
                <i class="bi bi-bar-chart-fill me-1"></i> Bar Chart
            </button>
            <button class="eb-view-tab" data-view="pie">
                <i class="bi bi-pie-chart-fill me-1"></i> Pie Chart
            </button>
        </div>
        <div class="eb-card-body p-0">
            <div id="errorAlert" class="eb-alert-error m-3 d-none"></div>
            <div id="noDataAlert" class="eb-empty-message m-3 d-none">
                <i class="bi bi-inbox me-1"></i> Query returned no rows.
            </div>
            <!-- Chart Configuration -->
            <div id="chartConfigPanel" class="eb-chart-config d-none">
                <div class="eb-chart-config-row">
                    <label class="eb-chart-config-label">
                        <i class="bi bi-tag me-1"></i> Label Column
                    </label>
                    <select id="chartLabelColumn" class="eb-chart-select">
                        <option value="">-- Select column --</option>
                    </select>
                </div>
                <div class="eb-chart-config-row">
                    <label class="eb-chart-config-label">
                        <i class="bi bi-123 me-1"></i> Value Column
                    </label>
                    <select id="chartValueColumn" class="eb-chart-select">
                        <option value="">-- Select column --</option>
                    </select>
                </div>
            </div>
            <!-- Data Grid -->
            <div class="table-responsive eb-data-grid" id="dataGridContainer">
                <table class="eb-results-table" id="resultsTable">
                    <thead id="resultsTableHead"></thead>
                    <tbody id="resultsTableBody"></tbody>
                </table>
            </div>
            <!-- Bar Chart -->
            <div id="barChartContainer" class="eb-chart-container d-none">
                <canvas id="barChartCanvas"></canvas>
            </div>
            <!-- Pie Chart -->
            <div id="pieChartContainer" class="eb-chart-container d-none">
                <canvas id="pieChartCanvas"></canvas>
            </div>
        </div>
        <div class="eb-card-footer" id="paginationContainer"></div>
    </div>
</div>

<!-- Table list data for JS -->
<script id="tableListData" type="application/json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Tables, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }))</script>
