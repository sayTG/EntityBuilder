@model EntityBuilder.ViewModels.TableDataViewModel
@{
    ViewData["Title"] = $"{Model.SchemaName}.{Model.TableName}";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Entity Builder</a></li>
        <li class="breadcrumb-item active">@Model.SchemaName.@Model.TableName</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>[@Model.SchemaName].[@Model.TableName]</h3>
    <a asp-action="Query"
       asp-route-sql="@($"SELECT TOP 100 * FROM [{Model.SchemaName}].[{Model.TableName}]")"
       class="btn btn-outline-primary btn-sm">Open in Query Editor</a>
</div>

<!-- Column Metadata -->
<div class="card mb-4">
    <div class="card-header" data-bs-toggle="collapse" data-bs-target="#columnInfo" role="button">
        <strong>Column Information</strong> (@Model.Columns.Count columns) <span class="float-end">Click to toggle</span>
    </div>
    <div id="columnInfo" class="collapse show">
        <div class="table-responsive">
            <table class="table table-sm table-bordered mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Column Name</th>
                        <th>Data Type</th>
                        <th>Max Length</th>
                        <th>Nullable</th>
                        <th>Default</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var col in Model.Columns)
                    {
                        <tr>
                            <td>@col.OrdinalPosition</td>
                            <td><strong>@col.ColumnName</strong></td>
                            <td><code>@col.DataType</code></td>
                            <td>@(col.MaxLength?.ToString() ?? "-")</td>
                            <td>
                                @if (col.IsNullable)
                                {
                                    <span class="badge bg-warning text-dark">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">No</span>
                                }
                            </td>
                            <td><code>@(col.ColumnDefault ?? "-")</code></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Data Grid -->
<div class="card">
    <div class="card-header d-flex justify-content-between">
        <strong>Data Preview</strong>
        @if (Model.Data.IsSuccess)
        {
            <span class="text-muted">@Model.Data.TotalRowsReturned rows returned in @Model.Data.ExecutionTimeMs ms</span>
        }
    </div>
    <div class="card-body p-0">
        @if (!Model.Data.IsSuccess)
        {
            <div class="alert alert-danger m-3">@Model.Data.ErrorMessage</div>
        }
        else if (Model.Data.Rows.Count == 0)
        {
            <div class="alert alert-info m-3">No data found.</div>
        }
        else
        {
            <div class="table-responsive eb-data-grid">
                <table class="table table-striped table-hover table-sm mb-0">
                    <thead class="table-dark sticky-top">
                        <tr>
                            @foreach (var col in Model.Data.Columns)
                            {
                                <th>@col</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Data.Rows)
                        {
                            <tr>
                                @foreach (var col in Model.Data.Columns)
                                {
                                    <td>@(row[col]?.ToString() ?? "<NULL>")</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
